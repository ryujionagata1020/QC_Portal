<!DOCTYPE html>
<html lang="ja">
  <head>
    <%- include("../_share/metadata.ejs") %>
    <title>QCの時間 - QC-Portal</title>
    <link rel="stylesheet" href="https://unpkg.com/ress/dist/ress.min.css" />
    <link rel="stylesheet" href="/public/index.css" />
  </head>
  <body>
    <div id="site-wrapper">
      <%- include("../_share/navbar.ejs") %>

      <main class="articles-index-container">
        <div class="articles-index-header">
          <h1>QCの時間（随時更新中）</h1>
          <div class="articles-index-intro">
            <img src="/public/qcnotimes.png" alt="QCの時間" class="articles-index-hero-img" />
            <p class="articles-index-desc">品質管理や統計手法の基礎から応用まで丁寧に解説しています。
            各級ごとに分野をカバーしております。各級のレベルを最後まで読み進め、試験対策を実施することでQC検定®に合格できる力が身につくこと目標にしています。<br>
            学習ページは数式ばかりではなく各業界の具体例を多数掲載し、はじめて品質管理を学ぶ方にもイメージ
            しやすい内容になっています。学習ページで勉強したあとは<a href="/questions/select?tab=custom">「試験対策」</a>で腕試ししてみましょう。
            すぐに解説がみれるようにしていますので、理解度をすぐに確認することができます。
            </p>
          </div>
        </div>

        <% const gradeLabels = { 4: '4級', 3: '3級', 2: '2級', 1: '1級' }; %>
        <% const sortedGrades = Object.keys(byGrade).map(Number).sort((a, b) => b - a); %>

        <% if (sortedGrades.length === 0) { %>
          <p class="articles-empty">記事は準備中です。もうしばらくお待ちください。</p>
        <% } else { %>
          <% for (const grade of sortedGrades) { %>
            <section class="articles-grade-section">
              <h2 class="articles-grade-title">QC検定® <%= gradeLabels[grade] || grade + '級' %></h2>
              <ul class="articles-list">
                <% for (const article of byGrade[grade]) { %>
                  <li class="articles-list-item">
                    <a href="/articles/learn/<%= article.slug %>">
                      <span class="articles-item-label">Chapter <%= article.chapter %></span>
                      <span class="articles-item-title"><%= article.title %></span>
                    </a>
                  </li>
                <% } %>
              </ul>
            </section>
          <% } %>
        <% } %>
      </main>

      <%- include("../_share/footer.ejs") %>
    </div>
    <%- include("../_share/javascripts.ejs") %>
  </body>
</html>
